---
import { iconMap, type IconName } from '../utils/iconMap';

interface Props {
  name: IconName;
  class?: string;
  [key: string]: any;
}

const { name, class: className, ...props } = Astro.props;
const svgContent = iconMap[name];
---

{svgContent ? (
  <span 
    {...props} 
    class={`inline-block fill-current ${className || ''}`} 
    set:html={svgContent} 
    aria-hidden="true"
  />
) : (
  <span aria-hidden="true" />
)}