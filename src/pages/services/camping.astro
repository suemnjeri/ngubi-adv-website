---
import Layout from '../../layouts/Layout.astro';
import Main from '../../layouts/Main.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LinkButton from '../../components/LinkButton.astro';
import Hr from "../../components/Hr.astro";


// Import the playful title image for the whole page
import GroupAdventureTitleImage from '/public/images/title-camping.webp';
// Import images
import CampingHeroTitle from '/public/images/title-camping-experience.webp'; // Placeholder name
import MagicCanopyImage from '/public/images/camping-image.webp';
import LogisticsImage from '/public/images/logistics-image3.webp';
import DiscoveryImage from '/public/images/discovery-image.webp';
import SafetyImage from '/public/images/safety-image1.webp'; // Use a photo of the forest/KFS for safety
---

<Layout title="Transformative Forest Camping - Ngubi Adventure Forest Camp">
  <Header />
  <Main pageTitle="" pageDesc="" class="pt-24 bg-surface text-foreground">

    {/* Playful Image Title for Combined Services */}
    <h1 class="sr-only">Group Adventure & Camping</h1>
    <div class="text-center mb-2 mx-auto max-w-4xl px-4">
        <img
            src={GroupAdventureTitleImage.src}
            alt="Group Adventure & Camping"
            width={GroupAdventureTitleImage.width}
            height={GroupAdventureTitleImage.height}
            class="w-full h-auto object-contain"
        />
    </div>

    {/* Introduction with Quote */}
    <section id ="camping-adventure" class="mb-12">
      <p class="text-lg text-center text-text-muted max-w-2xl mx-auto">
        More than just a night under the stars, our camping experience is a sensory journey designed to heal, connect, and inspire. Nestled within the high-altitude Kikuyu Escarpment Forest, we offer groups a rare opportunity to trade city noise for the symphony of the wild.
      </p>
      <blockquote class="text-xl italic font-light text-center text-foreground mt-8 px-4 border-l-4 border-accent pl-4 max-w-xl mx-auto">
        "In every walk with nature, one receives far more than he seeks."
        <cite class="block text-sm not-italic mt-2">- John Muir</cite>
      </blockquote>
    </section>

    <Hr />

    {/* Section 1: Camping */}
    <section id="camping" class="max-w-app mx-auto px-4 py-8 sm:py-12 flex flex-col md:flex-row items-center md:space-x-8 mb-2">
      <div class="md:w-1/2 mb-6 md:mb-0 relative rounded-lg overflow-hidden shadow-lg aspect-w-1 aspect-h-1 md:aspect-w-3 md:aspect-h-4">
        <img src={MagicCanopyImage.src} alt="Group camping in Ngubi forest" class="w-full h-full object-cover rounded-lg" loading="lazy">
        <div class="absolute inset-0 bg-black opacity-20 rounded-lg"></div>
      </div>
      <div class="md:w-1/2 text-text-muted">
        <h2 class="text-2xl font-bold mb-4 text-accent">Magic Under the Canopy</h2>
        <p class="text-text-muted mb-6">
          Our camping experience is built on three simple pillars of adventure: personal healing through nature, forging deep connections through teamwork, and active conservation. 
        </p>
        <ul class="space-y-4 text-text-muted">
          <li class="flex items-start">
            <span class="text-accent mr-2">✔</span> 
            <span><strong>The Vibe:</strong> Crackling bonfires, canopy storytelling, and absolute serenity.</span>
          </li>
          <li class="flex items-start">
            <span class="text-accent mr-2">✔</span> 
            <span><strong>The Atmosphere:</strong> A safe, respectful environment founded on Christian values of integrity and stewardship.</span>
          </li>
        </ul>

        
      </div>
    </section>

    <Hr />

    {/* Section 2: Full Logistics (Image Right) */}
    <section id="day-adventures" class="max-w-app mx-auto px-4 py-8 sm:py-12 flex flex-col md:flex-row-reverse items-center md:space-x-reverse md:space-x-8 mb-2">
      <div class="md:w-1/2 mb-6 md:mb-0 relative rounded-lg overflow-hidden shadow-lg aspect-w-1 aspect-h-1 md:aspect-w-3 md:aspect-h-4">
        <img src={LogisticsImage.src} alt="Youth group exploring the forest" class="w-full h-full object-cover rounded-lg" loading="lazy">
        <div class="absolute inset-0 bg-black opacity-20 rounded-lg"></div>
      </div>
      <div class="md:w-1/2 text-text-muted">
        <h2 class="text-2xl font-bold mb-4 text-accent">Full Logistics Support</h2>
        
        <p class="text-text-muted mb-2">
          We eliminate the stress of the outdoors. Whether you are a church group, youth club, or corporate team, you focus on the bond while we handle the heavy lifting.
        </p>
        <div class="grid grid-cols-1 gap-2 text-text-muted">
          {/* 2. NEW: Hot Showers Section */}
          <div class="bg-surface p-2 rounded-lg shadow-sm border-l-4 border-accent">
            <h4 class="font-bold text-foreground">Hot Showers in the Wild</h4> 
            <p class="text-sm">Our traditional wood-fired boiler ensures a constant supply of steaming hot water to help you shake off the forest chill.</p>
          </div>

          <div class="bg-surface p-2 rounded-lg shadow-sm border-l-4 border-accent">
            <h4 class="font-bold text-foreground">The Kichaka Grill (Full Board)</h4> 
            <p class="text-sm">Sustainably sourced, chef-prepared meals including breakfast, mid-morning snacks, hearty lunch, afternoon snacks, and supper.</p>
          </div>
          
          <div class="bg-surface p-2 rounded-lg shadow-sm border-l-4 border-accent">
            <h4 class="font-bold text-foreground">Premium Gear Provided (Optional)</h4>
            <p class="text-sm">High-quality tents, warm sleeping bags, and mats are provided for all participants.</p>
          </div>
          <div class="bg-surface p-2 rounded-lg shadow-sm border-l-4 border-accent">
            <h4 class="font-bold text-foreground">Modern Amenities</h4>
            <p class="text-sm">Access to our 15m x 12m Canopy Hall, clean gender-separated washrooms, commercial kitchen, and secure parking.</p>
          </div>
        </div>

        
      </div>
    </section>


    <Hr />

    {/* Section 3: Expert-Led Adventure (Image Left) */}
    <section id="teambuilding" class="max-w-app mx-auto px-4 py-8 sm:py-12 flex flex-col md:flex-row items-center md:space-x-8 mb-2">
      <div class="md:w-1/2 mb-6 md:mb-0 relative rounded-lg overflow-hidden shadow-lg aspect-w-1 aspect-h-1 md:aspect-w-3 md:aspect-h-4">
        <img src={DiscoveryImage.src} alt="Team collaborating on an obstacle course" class="w-full h-full object-cover rounded-lg" loading="lazy">
        <div class="absolute inset-0 bg-black opacity-20 rounded-lg"></div>
      </div>
      <div class="md:w-1/2 text-text-muted">
        <h2 class="text-2xl font-bold mb-4 text-accent">Adventure & Discovery</h2>
        <p class="text-text-muted mb-6">
          Your stay is anchored by discovery. Our resident naturalists guide you through a globally recognized Key Biodiversity Area (KBA).
        </p>
        <ul class="space-y-4 text-text-muted">
          <li><strong>The Ngubi Trail Quest:</strong> A 90-minute scavenger hunt using puzzles derived from our National Museums of Kenya Biodiversity Report.</li>
          <li><strong>Escarpment Challenge:</strong> Guided hikes ranging from leisurely 3km walks to the demanding 16km Rift Valley vista trek.</li>
          <li><strong>Active Conservation:</strong> Join our tree-planting initiatives to help rehabilitate the forest.</li>
        </ul>

      </div>
    </section>

    <Hr />

    {/* Section 4: Safety & Ethics (Full Width Highlight) */}
    <section id="day-adventures" class="max-w-app mx-auto px-4 py-8 sm:py-12 flex flex-col md:flex-row-reverse items-center md:space-x-reverse md:space-x-8 mb-2">
      <div class="md:w-1/2 mb-6 md:mb-0 relative rounded-lg overflow-hidden shadow-lg aspect-w-1 aspect-h-1 md:aspect-w-3 md:aspect-h-4">
        <img src={SafetyImage.src} alt="Youth group exploring the forest" class="w-full h-full object-cover rounded-lg" loading="lazy">
        <div class="absolute inset-0 bg-black opacity-20 rounded-lg"></div>
      </div>
      <div class="md:w-1/2 text-text-muted">
        <h2 class="text-2xl font-bold mb-4 text-accent">Uncompromising Safety & Ethics</h2>
        
        

        <div class="grid grid-cols-1 gap-4 text-text-muted">
          <div class="bg-surface p-4 rounded-lg shadow-sm border-l-4 border-accent">
            <h4 class="font-bold text-foreground">24/7 Professional Security</h4>
            <p class="text-sm">Our site is secured by a dedicated night watch team and reinforced by our partnership with <strong>Kenya Forest Service (KFS) </strong> for armed escorts during night sessions.</p>
          </div>
          <div class="bg-surface p-4 rounded-lg shadow-sm border-l-4 border-accent">
            <h4 class="font-bold text-foreground">Ethical Environment</h4>
            <p class="text-sm">We maintain a strict <strong>No-Alcohol</strong> and <strong>Single-Use Plastic Free</strong> policy to ensure a family-friendly, eco-conscious atmosphere.</p>
          </div>
          
        </div>


      </div>
    </section>    

    <Hr />

    {/* Call to Action & Inquiry Section (Updated) */}
    <section class="max-w-app mx-auto px-4 py-8 sm:py-12 text-center">
      <h2 class="text-3xl font-bold mb-6 text-accent">Plan Your Camping Adventure</h2>
      <p class="text-lg text-text-muted mb-8 max-w-2xl mx-auto">
        Ready to take your group into the heart of the forest? Contact us for a customized full-board quote.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <LinkButton
          href="/booking"
          class="inline-block px-8 py-4 text-lg bg-accent text-white rounded-full font-semibold whitespace-nowrap hover:bg-accent-dark hover:text-white transition-colors duration-200 shadow-lg"
          ariaLabel="Book Your Group Adventure"
          title="Book Your Group Adventure"
        >
          Book Now
        </LinkButton>
        <LinkButton
          href="/contact"
          class="inline-block px-8 py-4 text-lg bg-surface text-accent rounded-full font-semibold whitespace-nowrap hover:bg-gray-200 hover:text-accent transition-colors duration-200 shadow-lg"
          ariaLabel="Contact Us For More Info"
          title="Contact Us"
        >
          Contact Us
        </LinkButton>

        <LinkButton
          href="https://wa.me/254712505845?text=Hi! I'm interested in a Camping Inquiry for my group."
          target="_blank"
          class="inline-block px-8 py-4 text-lg bg-surface text-accent rounded-full font-semibold whitespace-nowrap hover:bg-gray-200 hover:text-accent transition-colors duration-200 shadow-lg"
          ariaLabel="Contact Us For More Info"
          title="Contact Us For More Info"
        >
          Send Camping Inquiry (WhatsApp)
        </LinkButton>
        
      </div>
    </section>


  </Main>
  <Footer />
</Layout>