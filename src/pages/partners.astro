---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Main from '../layouts/Main.astro';
import Hr from "../components/Hr.astro";
import LinkButton from '../components/LinkButton.astro';

{/* Partner Data Array: 
  Easily add or remove partners here in the future 
*/}
const partners = [
  {
    name: "Kenya Forest Service (KFS)",
    type: "Regulatory Partner", // <--- Added this field
    role: "Conservation & Security Authority",
    description: "Our primary partner in forest stewardship. Through a formal Community Forest Association (CFA) framework, we work together to ensure the safety, protection, and sustainable use of the Kikuyu Escarpment Forest.",
    // image: "/images/partners/kfs-logo.webp",
    image: "/images/gallery-14.webp",
    impact: "24/7 Forest Security & Compliance"
  },

  {
    name: "National Museums of Kenya",
    type: "Research Partner", // <--- Added this field
    role: "Scientific Research Partner",
    description: "Ngubi's operations are anchored in science. The NMK conducted our baseline biodiversity report, ensuring our presence supports the delicate ecosystem of the escarpment.",
    image: "/images/program-workshops1.webp",
    impact: "Biodiversity Monitoring & Preservation"
  },

  {
    name: "Nature Kenya",
    type: "Conservation Partner", // <--- Added this field
    role: "Biodiversity & Birding Partner",
    description: "As the oldest environmental society in Africa, Nature Kenya guides our birding programs. We host their expert-led birdwalks, helping document the 74+ species that call Ngubi home.",
    image: "/images/gallery-18.webp",
    impact: "Scientific Research & Birding Expertise"
  },
  
  {
    name: "Kijabe Forest Trust",
    type: "Community Partner", // <--- Added this field
    role: "Reforestation & Community Partner",
    description: "Our partners in 'Giving Back.' Together, we facilitate tree planting initiatives and community outreach, working to restore the indigenous canopy of the forest for future generations.",
    image: "/images/kijabe-forest-trust.webp",
    impact: "Indigenous Tree Planting & Restoration"
  }
];
---

<Layout title="Our Partners | Ngubi Adventure Forest">
  <Header />

  <Main pageTitle="" pageDesc="" class="pt-24 bg-white">
    
    {/* --- HEADER SECTION --- */}
    <div class="max-w-4xl mx-auto px-4 text-center mb-4">
      <img 
        src="/images/title-partners.webp" 
        alt="Our Strategic Partners" 
        class="w-full h-auto object-contain mb-8 shadow-sm rounded-xl"
      />
      <p class="text-xl text-muted-foreground leading-relaxed">
        No forest stands alone. We are proud to work alongside Kenya's leading conservation, scientific, and community organizations to create a secure and sustainable sanctuary.
      </p>

      <blockquote class="text-xl italic font-light text-center text-foreground mt-8 px-4 border-l-4 border-accent pl-4 max-w-xl mx-auto">
        "The forest is not a resource for us, it is a trust for our children. We protect it better when we protect it together."
        <cite class="block text-sm not-italic mt-2">- Indigenous Wisdom</cite>
      </blockquote>
    
    </div>

    <Hr />

    {/* --- UPDATED ALTERNATING OFFSET PARTNER GRID --- */}
    <section class="max-w-app mx-auto px-4 pb-8 mb-2">
        <div class="space-y-6">
            {partners.map((partner, index) => (
            <div class={`flex flex-col items-center gap-12 ${index % 2 === 0 ? 'md:flex-row' : 'md:flex-row-reverse'}`}>
                
                {/* Image Column: Cleaned up and theme-consistent */}
                <div class="w-full md:w-1/2 group">
                <div class="relative overflow-hidden rounded-3xl bg-surface p-2 aspect-video flex items-center justify-center border border-gray-600 dark:border-white/20 transition-all hover:shadow-xl dark:hover:bg-white/5">
                    <img 
                    src={partner.image} 
                    alt={partner.name} 
                    class="max-w-[85%] h-auto group-hover:grayscale-0 transition-all duration-700"
                    />
                </div>
                </div>

                {/* Text Column: Words moved here from the image */}
                <div class="w-full md:w-1/2 px-4">
                <div class="flex items-center gap-2 mb-4">
                    <span class="text-accent font-bold tracking-tighter text-3xl opacity-20">0{index + 1}</span>
                    <div class="h-px flex-grow bg-accent/20"></div>
                </div>

                {/* New Dynamic Label - Reflects the actual relationship */}
                <span class="text-[10px] uppercase font-bold tracking-[0.2em] text-accent mb-2 block">
                {partner.type}
                </span>

                <h2 class="text-3xl font-bold text-foreground mb-2">{partner.name}</h2>
                <h3 class="text-lg font-medium text-accent/80 mb-6 italic">{partner.role}</h3>
                
                <p class="text-lg text-muted-foreground leading-relaxed mb-8">
                    {partner.description}
                </p>
                
                <div class="inline-flex items-center gap-3 py-2 px-5 bg-accent/5 dark:bg-accent/10 rounded-full border border-accent/20">
                    <div class="w-2 h-2 rounded-full bg-accent animate-pulse"></div>
                    <span class="text-xs font-bold text-foreground uppercase tracking-wide">{partner.impact}</span>
                </div>
                </div>

            </div>
            ))}
        </div>
    </section>

    <Hr />

    {/* --- SIMPLIFIED PARTNERSHIP CTA --- */}
    <section class="max-w-4xl mx-auto py-8 px-4 text-center">
      <!-- <div class="h-px w-24 bg-accent/30 mx-auto mb-12"></div> -->
      
      <h2 class="text-2xl md:text-3xl font-bold text-accent mb-4 italic">
        Working on a conservation or community project?
      </h2>
      
      <p class="text-muted-foreground mb-10 text-lg max-w-2xl mx-auto">
        We are always looking for organizations that share our values of integrity, stewardship, and safety.
      </p>

      <LinkButton
        href="/contact"
        class="inline-block px-8 py-4 text-lg bg-accent text-white rounded-full font-semibold whitespace-nowrap hover:bg-accent-dark hover:text-white transition-colors duration-200 shadow-lg"
        ariaLabel="Inquire About Partnership"
        title="Inquire About Partnership"
      >
        Let Us Collaborate
      </LinkButton>

      <LinkButton
          href="https://wa.me/254712505845?text=Hi! I'm interested in a Partnership Inquiry for my organization."
          target="_blank"
          class="inline-block px-8 py-4 text-lg bg-surface text-accent rounded-full font-semibold whitespace-nowrap hover:bg-gray-200 hover:text-accent transition-colors duration-200 shadow-lg"
          ariaLabel="Contact Us For More Info"
          title="Contact Us For More Info"
        >
          Send Inquiry (WhatsApp)
        </LinkButton>

    </section>

  </Main>
  <Footer />
</Layout>