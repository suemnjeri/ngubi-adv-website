---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Main from "../../layouts/Main.astro";
import Datetime from "../../components/Datetime.astro";
import { SITE } from "../../config";

// 1. Tell Astro which dynamic tag routes exist based on your markdown collection records
export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const uniqueTags = [...new Set(posts.flatMap(post => post.data.tags))];

  return uniqueTags.map(tag => {
    // Filter down to only posts containing the specific loop tag
    const filteredPosts = posts.filter(post => post.data.tags.includes(tag));
    return {
      params: { tag },
      props: { posts: filteredPosts, tagName: tag },
    };
  });
}

const { posts, tagName } = Astro.props;
const defaultOgImage = "/assets/default-og.png";
---

<Layout title={`Category: #${tagName} | ${SITE.title}`}>
  <Header />
  
  {/* Using a margin-top div completely bypasses component property bugs */}
  <Main pageTitle="" pageDesc="">
    {/* This inner container mimics your booking and about pages layout perfectly */}
    <div class="pt-10 pb-12 max-w-6xl mx-auto px-6 bg-surface text-foreground">
      
      <div class="mb-6">
        <a href="/news/" class="text-skin-accent hover:underline text-sm font-medium">
          ← Back to News Center
        </a>
      </div>

      <h1 class="text-4xl font-bold mb-2 text-skin-base">Category: #{tagName}</h1>
      <p class="text-skin-muted mb-8">Showing all articles tagged with #{tagName}</p>

      <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-6">
        {posts.map(post => {
          const imageUrl = typeof post.data.ogImage === 'string' 
            ? post.data.ogImage 
            : (post.data.ogImage?.src || "/assets/default-og.png");

          return (
            <li class="flex flex-col border border-skin-line rounded-lg overflow-hidden bg-skin-card shadow-sm transition-transform duration-200 hover:-translate-y-1 group">
              <a href={`/news/${post.id}/`} class="block overflow-hidden aspect-video bg-neutral-200">
                <img 
                  src={imageUrl} 
                  alt={`Featured image for ${post.data.title}`}
                  class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
              </a>
              
              <div class="flex flex-col flex-grow p-5">
                <a href={`/news/${post.id}/`} class="inline-block rounded">
                  <h3 class="text-xl font-semibold text-skin-base group-hover:text-skin-accent transition-colors duration-200 line-clamp-2 leading-snug">
                    {post.data.title}
                  </h3>
                </a>
                
                <div class="mt-2 text-sm text-skin-muted">
                  <Datetime pubDatetime={post.data.pubDatetime} modDatetime={post.data.modDatetime} />
                </div>
                
                <p class="mt-3 text-skin-base opacity-80 text-sm line-clamp-3 flex-grow">
                  {post.data.description}
                </p>
              </div>
            </li>
          );
        })}
      </ul>
    </div>
    </Main>
  <!-- </div> -->
  
  <Footer />
</Layout>