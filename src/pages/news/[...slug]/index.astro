---
import { getCollection, render } from "astro:content"; // Imported render here
import Layout from "../../../layouts/Layout.astro";
import Main from "../../../layouts/Main.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import Datetime from "../../../components/Datetime.astro";
import { SITE } from "../../../config";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;

// Use the native render function passing the post object into it
const { Content } = await render(post);
---

<Layout title={`${post.data.title} | ${SITE.title}`}>
  <Header />
    <Main pageTitle="" pageDesc="">
    {/* Pushes the article content down beautifully under the fixed header */}
    <div class="pt-6 pb-16 max-w-3xl mx-auto px-6 bg-surface text-foreground">

      <div class="mx-auto max-w-3xl px-4 pt-10 pb-16">
        <a 
          href="/news/" 
          class="inline-flex items-center gap-2 mb-6 text-skin-accent hover:underline text-sm font-medium"
        >
          ← Back to News Center
        </a>

        <header class="mb-8">
          <h1 class="text-3xl sm:text-4xl font-bold text-skin-base tracking-tight mb-3">
            {post.data.title}
          </h1>
          
          <div class="text-skin-muted text-sm">
            <Datetime 
              pubDatetime={post.data.pubDatetime} 
              modDatetime={post.data.modDatetime} 
            />
          </div>
        </header>

        <article class="prose max-w-none prose-skin mt-8 dark:prose-invert leading-relaxed text-skin-base">
          <Content />
        </article>
      </div>

    </div>
    </Main>

  <Footer />
</Layout>

<style is:global>
  article p { 
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }
  article h2 { 
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  article h3 { 
    font-size: 1.25rem;
    font-weight: 500;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  article ul { 
    list-style-type: disc; 
    padding-left: 1rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }
  article ol { 
    list-style-type: decimal; 
    padding-left: 1rem;
    margin-top: 1rem;
    margin-bottom: 1rem;
  }
  article li {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }
  article code { 
    background-color: var(--color-card-muted, #f3f4f6);
    padding: 0.125rem 0.375rem; 
    border-radius: 0.25rem;
    font-family: monospace;
    font-size: 0.875rem; 
  }
  article pre { 
    background-color: #171717; 
    color: #f5f5f5;
    padding: 1rem; 
    border-radius: 0.5rem; 
    overflow-x: auto; 
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    font-family: monospace;
    font-size: 0.875rem;
  }
  article blockquote { 
    border-left-width: 4px; 
    border-left-style: solid;
    padding-left: 1rem; 
    font-style: italic; 
    margin-top: 1.5rem;
    margin-bottom: 1.5rem; 
    opacity: 0.9;
  }
  article img { 
    border-radius: 0.5rem; 
    margin-top: 1.5rem;
    margin-bottom: 1.5rem; 
    max-width: 100%; 
    height: auto; 
    display: block;
    margin-left: auto;
    margin-right: auto;
  }
</style>